{
    "name": "comments-highlighter",
    "displayName": "Project Memory - Code Context & Annotations",
    "description": "Capture the WHY behind your codebase. Link architectural decisions, bug workarounds, and notes directly to code lines.",
    "publisher": "mahesh-abeykoon",
    "version": "0.2.2",
    "icon": "media/logo.png",
    "keywords": [
        "documentation",
        "code-context",
        "notes",
        "annotations",
        "todo-scanner",
        "knowledge-base",
        "reasoning"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/Mahesh-Abeykoon/project-memory-extension"
    },
    "license": "MIT",
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": ["Other"],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "project-memory",
                    "title": "Project Memory",
                    "icon": "media/project-memory.svg"
                }
            ]
        },
        "views": {
            "project-memory": [
                {
                    "type": "webview",
                    "id": "project-memory.sidebar",
                    "name": "Memories",
                    "icon": "media/project-memory.svg"
                }
            ]
        },
        "commands": [
            {
                "command": "project-memory.addMemory",
                "title": "🧠 Add to Project Memory"
            },
            {
                "command": "project-memory.clearAll",
                "title": "Project Memory: Clear All Memories"
            },
            {
                "command": "project-memory.focusSidebar",
                "title": "Project Memory: Focus Sidebar"
            },
            {
                "command": "project-memory.exportMarkdown",
                "title": "Project Memory: Export Memories as Markdown (PR / Docs)"
            },
            {
                "command": "project-memory.scanComments",
                "title": "Project Memory: Scan Workspace Comments"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "command": "project-memory.addMemory",
                    "group": "navigation",
                    "when": "editorHasSelection"
                }
            ]
        },
        "configuration": {
            "title": "Project Memory",
            "properties": {
                "project-memory.authorName": {
                    "type": "string",
                    "default": "",
                    "description": "The author name to use when saving memories. If left empty, it will auto-detect your Git username or system username."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "node esbuild.js",
        "watch": "node esbuild.js --watch"
    },
    "devDependencies": {
        "@types/node": "^18.11.18",
        "@types/vscode": "^1.75.0",
        "esbuild": "^0.17.5",
        "typescript": "^4.9.5"
    }
}
